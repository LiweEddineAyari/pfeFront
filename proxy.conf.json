{
  "/api/parameters": {
    "target": "http://localhost:8081",
    "secure": false,
    "changeOrigin": true,
    "logLevel": "debug",
    "timeout": 600000,
    "pathRewrite": {
      "^/api/parameters": "/parameters"
    }
  },

  "/api/ratios": {
    "target": "http://localhost:8081",
    "secure": false,
    "changeOrigin": true,
    "logLevel": "debug",
    "timeout": 600000,
    "pathRewrite": {
      "^/api/ratios": "/ratios"
    }
  },

  "/api": {
    "target": "http://localhost:8081",
    "secure": false,
    "changeOrigin": true,
    "logLevel": "debug",
    "timeout": 600000,
    "pathRewrite": {
      "^/api/ratios": "/ratios",
      "^/api/parameters": "/parameters"
    }
  }
}
